{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cai.canine.dev/schemas/cai-delivery-1.0.schema.json",
  "title": "CAI-delivery package",
  "description": "A signed (Ed25519), tamper-evident, portable CAI evidence artifact: a point-in-time CAI verdict cai.canine.dev recomputed, the evidence it folds from, and the provenance — with a detached signature over the payload's canonical form. Format version 1.x (MAJOR 1). A verifier MUST reject a package whose payload.schemaVersion MAJOR it does not implement; a higher MINOR is forward-compatible and unknown fields are ignored.",
  "type": "object",
  "required": ["payload", "signature"],
  "additionalProperties": false,
  "properties": {
    "payload": { "$ref": "#/$defs/payload" },
    "signature": { "$ref": "#/$defs/signature" }
  },
  "$defs": {
    "payload": {
      "type": "object",
      "description": "The signed content — everything here is covered by the signature.",
      "required": ["schemaVersion", "deliveryId", "issuedAt", "issuer", "producer", "subject", "rubricVersion", "verdict", "evidence"],
      "additionalProperties": true,
      "properties": {
        "schemaVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$",
          "description": "Package format version MAJOR.MINOR. This document describes MAJOR 1.",
          "examples": ["1.0"]
        },
        "deliveryId": { "type": "string", "minLength": 1, "description": "cai's stable id for this delivery." },
        "issuedAt": { "type": "string", "format": "date-time", "description": "When cai signed the delivery (RFC 3339 UTC)." },
        "issuer": {
          "type": "object",
          "required": ["name", "keyId"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "description": "The signer — cai.canine.dev." },
            "keyId": { "type": "string", "minLength": 1, "description": "The signing key id; must equal signature.keyId." }
          }
        },
        "producer": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1, "description": "Who measured the code (the authenticated producer)." },
            "scanner": { "type": "string", "description": "The analyzer that produced the evidence." },
            "scannerVersion": { "type": "string", "description": "The analyzer build version." }
          }
        },
        "subject": {
          "type": "object",
          "required": ["repository"],
          "additionalProperties": false,
          "properties": {
            "repository": { "type": "string", "minLength": 1, "description": "Repository identity, e.g. acme/checkout-api." },
            "commit": { "type": ["string", "null"], "description": "The commit measured." },
            "host": { "type": ["string", "null"], "description": "Optional forge, e.g. github.com." }
          }
        },
        "rubricVersion": { "type": "string", "minLength": 1, "description": "The frozen rubric version the verdict was computed under." },
        "qualityBar": {
          "type": ["string", "null"],
          "description": "The quality bar band cutlines follow (absent => production baseline)."
        },
        "measurement": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "measuredLoc": { "type": ["integer", "null"], "minimum": 0 },
            "productionLoc": { "type": "integer", "minimum": 0 },
            "analyzableProjects": { "type": "integer", "minimum": 0 },
            "scannedAt": { "type": ["string", "null"], "format": "date-time" }
          }
        },
        "verdict": { "$ref": "#/$defs/verdict" },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "verdict": {
      "type": "object",
      "description": "The CAI verdict cai recomputed from the embedded evidence.",
      "required": ["cai", "band", "lenses"],
      "additionalProperties": false,
      "properties": {
        "cai": { "type": "number", "minimum": 0, "maximum": 100, "description": "The 0-100 headline CAI." },
        "band": { "$ref": "#/$defs/bandLabel" },
        "aggregate": { "type": "number", "minimum": 0, "maximum": 100 },
        "categoryMean": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "coherenceNote": { "type": "string" },
        "lenses": { "type": "array", "items": { "$ref": "#/$defs/lens" } },
        "categories": { "type": "array", "items": { "$ref": "#/$defs/category" } }
      }
    },
    "lens": {
      "type": "object",
      "required": ["lens", "score", "band"],
      "additionalProperties": false,
      "properties": {
        "lens": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "band": { "$ref": "#/$defs/bandLabel" },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "contribution": { "type": "number", "minimum": 0, "maximum": 100 },
        "criticalGated": { "type": "boolean" },
        "criticalContributors": { "type": "array", "items": { "type": "string" } },
        "itemCount": { "type": "integer", "minimum": 0 }
      }
    },
    "category": {
      "type": "object",
      "required": ["category", "lens", "dimensionCount"],
      "additionalProperties": false,
      "properties": {
        "category": { "type": "string" },
        "lens": { "type": "string" },
        "score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "dimensionCount": { "type": "integer", "minimum": 0 }
      }
    },
    "evidence": {
      "type": "object",
      "description": "The embedded evidence bundle the verdict folds from (see the Cai.Scoring evidence-bundle contract). Its presence is what makes the package independently reproducible.",
      "required": ["rubricVersion"],
      "additionalProperties": true,
      "properties": {
        "rubricVersion": { "type": "string", "minLength": 1 },
        "commit": { "type": ["string", "null"] },
        "qualityBar": { "type": ["string", "null"] },
        "analyzableProjects": { "type": "integer", "minimum": 0 },
        "productionLoc": { "type": "integer", "minimum": 0 },
        "headlineScore": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "dimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "category", "score", "confidence"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "category": { "type": "string" },
              "score": { "type": "number", "minimum": 0, "maximum": 10 },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
              "advisory": { "type": "boolean" }
            }
          }
        },
        "metaDimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "lens"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "lens": { "type": "string" },
              "score": { "type": ["number", "null"], "minimum": 0, "maximum": 10 },
              "advisory": { "type": "boolean" }
            }
          }
        },
        "lenses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["lens", "score", "owaWeight"],
            "additionalProperties": false,
            "properties": {
              "lens": { "type": "string" },
              "score": { "type": "number", "minimum": 0, "maximum": 100 },
              "owaWeight": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "description": "The detached Ed25519 signature over the payload's canonical (RFC 8785-targeting) form.",
      "required": ["alg", "keyId", "canon", "value"],
      "additionalProperties": false,
      "properties": {
        "alg": { "const": "Ed25519", "description": "RFC 8032 PureEdDSA." },
        "keyId": { "type": "string", "minLength": 1, "description": "The public key to verify with; must equal payload.issuer.keyId." },
        "canon": { "const": "RFC8785-json", "description": "The canonicalization method the signed bytes were produced by." },
        "value": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]+$",
          "description": "base64url (unpadded) of the 64-byte Ed25519 signature."
        }
      }
    },
    "bandLabel": {
      "type": "string",
      "enum": ["Exemplary", "Strong", "Adequate", "Weak", "Critical"],
      "description": "The published CAI band vocabulary."
    }
  }
}
