{
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": "Codebase Assurance Index (CAI)",
  "description": "An open, reproducible 0–100 standard for the health of a C#/.NET codebase. Same code in, same score out — a deterministic measurement anyone can verify.",
  "url": "https://cai.canine.dev/",
  "hasDefinedTerm": [
    {
      "@type": "DefinedTerm",
      "name": "Codebase Assurance Index",
      "termCode": "CAI",
      "description": "One reproducible 0–100 score for a whole codebase, computed deterministically from evidence under a frozen, versioned rubric — a credit score for software."
    },
    {
      "@type": "DefinedTerm",
      "name": "Lens",
      "termCode": "lens",
      "description": "A grouping of dimensions that measures one facet of a codebase (e.g. Code Health, Architecture, Security & Compliance). The CAI is composed of ten lenses."
    },
    {
      "@type": "DefinedTerm",
      "name": "Rubric version",
      "termCode": "rubric-version",
      "description": "The frozen, versioned definition of how the CAI is computed. A score is always reported with its rubric version, making it reproducible to exact criteria."
    },
    {
      "@type": "DefinedTerm",
      "name": "Survey",
      "termCode": "survey",
      "description": "An independent, signed assessment that pairs the CAI with the deductions — what's wrong, what it means, what to do — issued by the surveyor. The judgment layer above the open standard."
    },
    {
      "@type": "DefinedTerm",
      "name": "Registry",
      "termCode": "registry",
      "description": "The public record of signed surveys — open, falsifiable: anyone can re-run the open scorer against the evidence and reproduce the number."
    }
  ]
}
