@page "/calculator"
@inject RubricCatalogStore Store

<PageTitle>CAI — calculator</PageTitle>

<div class="hero"><div class="wrap">
    <p class="eyebrow">Compute it yourself</p>
    <h1>Score an evidence bundle.</h1>
    <p class="lede">Paste an <a href="/spec#evidence">evidence bundle</a> — the measured dimensions and lenses — and
        the open scorer folds it into the CAI, worst-first, entirely in the open. Producing the bundle is the analyzer's
        job; scoring it is this, and anyone can reproduce it.</p>
</div></div>

<section><div class="wrap">
    <EditForm FormName="calc" Model="Op" OnValidSubmit="DoScore">
        <p><label class="muted small" for="ev">Evidence bundle (JSON)</label></p>
        <textarea id="ev" name="Op.Json" rows="14" style="width:100%;font-family:var(--mono);font-size:.85rem;"
                  placeholder='{ "rubricVersion": "...", "lenses": [ { "lens": "codeHealth", "score": 86, "owaWeight": 0.14 }, ... ] }'>@Op.Json</textarea>
        <div class="btns">
            <button class="btn primary" type="submit">Compute the CAI</button>
            <button class="btn" type="submit" name="Op.Sample" value="true">Load the sample bundle</button>
        </div>
    </EditForm>

    @if (_error is not null)
    {
        <div class="callout" style="border-color:var(--crit)"><strong>Couldn't score that:</strong> @_error</div>
    }
    else if (_score is not null)
    {
        <h2 style="margin-top:2rem">CAI @($"{_score.Headline:0}") <span class="band b-@BandClass(_score.Band)">@_score.Band.Label()</span></h2>
        <p class="muted">rubric @(_score.RubricVersion is { Length: > 0 } r ? r : "(unstated)") · headline =
            Σ(lensScore × weight) = @($"{_score.Headline:0.00}")</p>
        <table class="lenses">
            <thead><tr><th>Lens</th><th>Score</th><th>Weight</th><th>Contribution</th></tr></thead>
            <tbody>
                @foreach (var c in _score.Contributions.OrderByDescending(c => c.Contribution))
                {
                    <tr><td>@c.Lens</td><td>@($"{c.Score:0.0}")</td><td>@($"{c.Weight:0.000}")</td><td>@($"{c.Contribution:0.00}")</td></tr>
                }
            </tbody>
        </table>
    }
</div></section>

@code {
    [SupplyParameterFromForm] public CalcForm? Op { get; set; }

    private CaiScore? _score;
    private string? _error;

    public sealed class CalcForm
    {
        public string? Json { get; set; }
        public bool Sample { get; set; }
    }

    protected override void OnInitialized() => Op ??= new();

    private void DoScore()
    {
        _score = null;
        _error = null;
        if (Op!.Sample || string.IsNullOrWhiteSpace(Op.Json))
        {
            Op.Json = SampleJson();
            if (Op.Sample) { return; } // just populate the textarea
        }

        try
        {
            _score = CaiScorer.Score(EvidenceBundle.Parse(Op.Json!));
        }
        catch (Exception e)
        {
            _error = e.Message;
        }
    }

    private static string BandClass(Band b) => b switch
    {
        Band.Exemplary => "exemplary", Band.Healthy => "strong", Band.Fair => "adequate", Band.Poor => "weak", _ => "critical",
    };

    private string SampleJson() =>
        """
        {
          "rubricVersion": "rubric-2026.08.15",
          "headlineScore": 72.2,
          "lenses": [
            { "lens": "securityCompliance",  "score": 58, "owaWeight": 0.24 },
            { "lens": "maturity",            "score": 65, "owaWeight": 0.20 },
            { "lens": "architecture",        "score": 72, "owaWeight": 0.18 },
            { "lens": "codeHealth",          "score": 86, "owaWeight": 0.14 },
            { "lens": "productionReadiness", "score": 80, "owaWeight": 0.12 },
            { "lens": "accessibility",       "score": 90, "owaWeight": 0.06 },
            { "lens": "performance",         "score": 88, "owaWeight": 0.06 }
          ]
        }
        """;
}
